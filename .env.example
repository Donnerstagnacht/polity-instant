# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Postgres (direct connection for Zero cache server)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Zero Cache
ZERO_CACHE_URL=http://localhost:4848

# Application URL
APP_URL=http://localhost:3000

# Client-side (Vite requires VITE_ prefix)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ZERO_CACHE_URL=http://localhost:4848
VITE_APP_URL=http://localhost:3000

# Stripe Payment Integration (Optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# OpenAI Integration (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Web Push Notifications (VAPID Keys)
# Generate keys by running: node scripts/generate-vapid-keys.ts
VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_EMAIL="mailto:your-email@example.com"
