# Environment strategy
#
# - .env.development.local  => Supabase local development
# - .env.production.local   => Supabase cloud / production build values
# - .env                    => keep empty or use only for shared non-sensitive defaults
#
# Vinxi/Vite resolves these files automatically by mode.
# Copy the block below into the appropriate mode-specific file and adjust values.

# Web Push Notifications (VAPID Keys)
VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_EMAIL="mailto:your-email@example.com"
VITE_VAPID_PUBLIC_KEY="your_vapid_public_key_here"

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_or_secret_key_here

# Zero Cache
VITE_ZERO_CACHE_URL=https://zero.your-domain.example

# App
VITE_APP_URL=https://your-app-domain.example

# Database
# Vercel: use session pooler (pooler.supabase.com:5432)
# Fly.io zero-cache: override ZERO_UPSTREAM_DB with direct connection via `fly secrets set`
#   ZERO_UPSTREAM_DB=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require
ZERO_UPSTREAM_DB=postgresql://postgres.your-project:your_database_password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
ZERO_CVR_DB=postgresql://postgres.your-project:your_database_password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
ZERO_CHANGE_DB=postgresql://postgres.your-project:your_database_password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
ZERO_ADMIN_PASSWORD=your_zero_admin_password_here

# Stripe Payment Integration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
VITE_STRIPE_PRICE_RUNNING=your_stripe_price_running_here
VITE_STRIPE_PRICE_DEVELOPMENT=your_stripe_price_development_here

